# .env.example — copy ไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ห้าม commit ไฟล์ .env เด็ดขาด

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # ใช้เฉพาะ server
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...     # ใช้ใน frontend ได้

# Gemini (https://aistudio.google.com)
GEMINI_API_KEY=AIzaSy...

# Line Messaging API (รับรูปจากแม่ค้า)
# ได้จาก developers.line.biz → Messaging API Channel
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxx...

# Line Login (ลูกค้า login)
# ได้จาก developers.line.biz → Line Login Channel
LINE_LOGIN_CHANNEL_ID=1234567890
LINE_LOGIN_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_LOGIN_REDIRECT_URI=https://your-shop-domain.com/auth/callback

# Line Notify (แจ้งเจ้าของ)
# ได้จาก notify-bot.line.me → Generate token
LINE_NOTIFY_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ความปลอดภัย
SUPPLIER_LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # LINE userId ของแม่ค้า
ADMIN_SECRET=your-strong-password-here                   # password หน้า admin

# Server
PORT=3000
NODE_ENV=production
